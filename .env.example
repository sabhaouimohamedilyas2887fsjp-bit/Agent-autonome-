# ============================================================
# Veille Juridique Maroc – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ----------------------------------------------------------
# Required
# ----------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# ----------------------------------------------------------
# Database (optional – defaults to SQLite if not set)
# ----------------------------------------------------------
DATABASE_URL=sqlite:///veille_juridique.db
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/veille_juridique

# ----------------------------------------------------------
# Email / SMTP (required only if alerts.email.enabled: true)
# ----------------------------------------------------------
SMTP_USERNAME=votre.email@gmail.com
SMTP_PASSWORD=votre_mot_de_passe_application
SMTP_FROM=votre.email@gmail.com

# ----------------------------------------------------------
# Slack (required only if alerts.slack.enabled: true)
# ----------------------------------------------------------
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXXX/YYYYY/ZZZZZ
